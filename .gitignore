name: Build Android APK via PWABuilder CloudAPK

on:
  workflow_dispatch:
    inputs:
      github_username:
        description: 'GitHub username (no @)'
        required: true
        default: 'yadgari-commits'
        type: string
      repo_name:
        description: 'Repository name'
        required: true
        default: 'YTG-Compaction-Test'
        type: string

jobs:
  build-apk:
    name: Build APK
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - name: 📥 Checkout repository
        uses: actions/checkout@v4

      - name: 🔧 Install unzip
        run: sudo apt-get install -y unzip

      - name: 🔍 Wait for PWA to be live
        env:
          GH_USER: ${{ inputs.github_username }}
          REPO_NAME: ${{ inputs.repo_name }}
        run: |
          PWA_URL="https://${GH_USER}.github.io/${REPO_NAME}"
          echo "🌐 PWA URL: $PWA_URL"
          for i in {1..12}; do
            HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" "$PWA_URL/index.html" || echo "000")
            if [ "$HTTP_CODE" = "200" ]; then
              echo "✅ PWA is live (attempt $i, HTTP 200)"
              exit 0
            fi
            echo "⏔ Attempt $i/12: HTTP $HTTP_CODE, retrying in 5s..."
            sleep 5
          done
          echo "::error::PWA not reachable at $PWA_URL after 60s"
          exit 1

      - name: 🏗️ Build APK with PWABuilder CloudAPK
        env:
          GH_USER: ${{ inputs.github_username }}
          REPO_NAME: ${{ inputs.repo_name }}
        run: |
          set -e
          PWA_URL="https://${GH_USER}.github.io/${REPO_NAME}"
          echo "🌐 Building APK from: $PWA_URL"

          PAYLOAD="{\"name\":\"Civil Master Pro\",\"launcherName\":\"YTG Compaction\",\"packageId\":\"com.yadgari.civilmasterpro\",\"host\":\"${PWA_URL}\",\"startUrl\":\"/?source=pwa\",\"themeColor\":\"#fbbf24\",\"backgroundColor\":\"#0f172a\",\"navigationColor\":\"#000000\",\"iconUrl\":\"${PWA_URL}/icons/icon-512.png\",\"maskableIconUrl\":\"${PWA_URL}/icons/icon-512-maskable.png\",\"webManifestUrl\":\"${PWA_URL}/manifest.json\",\"display\":\"standalone\",\"orientation\":\"default\",\"fallbackType\":\"customtabs\",\"appVersion\":\"4.0.0\",\"appVersionCode\":40,\"enableNotifications\":false,\"signingMode\":\"none\",\"splashScreenFadeOutDuration\":300,\"additionalTrustedOrigins\":[],\"features\":{\"locationDelegation\":{\"enabled\":false},\"playBilling\":{\"enabled\":false}}}"

          echo "=== Calling PWABuilder CloudAPK ==="
          OUTPUT_ZIP=$(mktemp --suffix=.zip)
          HTTP_CODE=$(curl -s -o "$OUTPUT_ZIP" -w "%{http_code}" -X POST \
            "https://pwabuilder-cloudapk.azurewebsites.net/generateAppPackage" \
            -H "Content-Type: application/json" \
            -d "$PAYLOAD")

          echo "HTTP Status: $HTTP_CODE"
          echo "Response size: $(du -h "$OUTPUT_ZIP" | cut -f1)"

          if [ "$HTTP_CODE" != "200" ]; then
            echo "::error::PWABuilder CloudAPK returned HTTP $HTTP_CODE"
            head -c 2000 "$OUTPUT_ZIP"
            exit 1
          fi

          FILE_TYPE=$(file -b "$OUTPUT_ZIP" 2>/dev/null || echo "unknown")
          echo "File type: $FILE_TYPE"

          if [[ "$FILE_TYPE" != *"Zip archive"* ]] && [[ "$FILE_TYPE" != *"zip"* ]] && [[ "$FILE_TYPE" != *"ASCII"* ]]; then
            echo "::error::Response is not a zip file"
            head -c 2000 "$OUTPUT_ZIP"
            exit 1
          fi

          rm -rf ./extracted
          mkdir -p ./extracted
          unzip -o "$OUTPUT_ZIP" -d ./extracted

          find ./extracted -name "*.apk" -exec cp {} civil-master-pro.apk \;

          if [ ! -f "civil-master-pro.apk" ] || [ ! -s "civil-master-pro.apk" ]; then
            echo "::error::No APK found"
            find ./extracted -type f
            exit 1
          fi

          echo "✅ APK ready: $(du -h civil-master-pro.apk | cut -f1)"
          ls -la *.apk

      - name: 📤 Upload APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: civil-master-pro-apk
          path: |
            *.apk
          if-no-files-found: error
          retention-days: 30

      - name: ✅ Build summary
        if: success()
        run: |
          {
            echo "## 🎉 APK Build Successful!"
            echo ""
            echo "**APK files:**"
            for f in *.apk; do
              [ -f "$f" ] && echo "- \`$f\` ($(du -h "$f" | cut -f1))"
            done
          } >> $GITHUB_STEP_SUMMARY
